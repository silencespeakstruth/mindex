#!/bin/sh
#
# mindex-search-edit — POSIX sh pipeline glue: $EDITOR (multi-line query) |
# mindex-search | render.
#
# Pure POSIX sh. No bashisms, no arrays, no [[ ]], no `local`. Tested against
# dash. Assumes nothing about the environment beyond the standard utilities
# named below and the conventional $EDITOR variable.
#
# Pipeline:
#   1. Open $EDITOR (fallback: vi) on a fresh temp file so the user can type
#      a multi-line search query. (Skipped if $MINDEX_QUERY is set — see
#      below — which makes this script usable non-interactively too.)
#   2. Pipe the file's contents into the mindex-search binary, translating
#      MINDEX_* environment variables into its flags.
#   3. Let mindex-search render the results or report the error; this
#      script's own job is just to fail loudly and clearly anywhere upstream
#      of that (missing tools, missing required variables, empty query,
#      editor aborted, etc).
#
# Required tools: a POSIX sh, mktemp, grep, tr, command. Plus the
# mindex-search binary itself (resolved via $MINDEX_SEARCH_BIN, alongside
# this script, or on $PATH — see --help).

set -eu
# set -f disables pathname expansion so glob patterns like 'src/**' reach
# mindex-search literally, never expanded by this shell.
set -f

prog=$(basename -- "$0")

# ─── Output helpers ─────────────────────────────────────────────────────────

warn() {
    printf '%s: %s\n' "$prog" "$1" >&2
}

die() {
    printf '%s: error: %s\n' "$prog" "$1" >&2
    exit 1
}

# ─── Help ───────────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF
Usage: $prog [-- EXTRA-MINDEX-SEARCH-ARGS...]

Opens \$EDITOR on a temp file for a multi-line search query, then pipes it
into the mindex-search binary and lets it render the results or the error.

All search parameters are read from environment variables (so this script
itself takes no flags of its own besides -h/--help). Any arguments given on
the command line are forwarded verbatim to mindex-search, appended after the
flags derived from environment variables below — so a CLI argument always
overrides the same setting coming from an environment variable.

Environment variables — connection:
  MINDEX_SEARCH_BIN     Path to the mindex-search binary. Default: looked up
                         next to this script, then on \$PATH.
  MINDEX_SERVER          mindex server URL. Default: mindex-search's own
                         default (https://127.0.0.1:11111).
  MINDEX_PROJECT         Project GUID, 32-char hex without dashes. REQUIRED.
  MINDEX_PROTOCOL        API version in the URL path. Default: v0.
  MINDEX_NO_VERIFY       If set to one of 1/true/yes/on (case-insensitive),
                         skip TLS certificate verification.

Environment variables — search parameters:
  MINDEX_TOP_K           Max results to request, e.g. MINDEX_TOP_K=32.
  MINDEX_INCLUDE_LANG    Space-separated language list, e.g. "rust python".
  MINDEX_INCLUDE_PATH    Space-separated glob list, e.g. "src/** tests/**".
  MINDEX_EXCLUDE_LANG    Space-separated language list to exclude.
  MINDEX_EXCLUDE_PATH    Space-separated glob list to exclude.

Environment variables — presentation:
  MINDEX_THEME           Pygments style name for syntax highlighting.
  MINDEX_COLOR           always | auto | never. Default: auto.
  MINDEX_VERBOSE         If truthy (see MINDEX_NO_VERIFY), print the
                         outgoing request JSON to stderr for debugging.

Environment variables — input:
  EDITOR                 Editor used for interactive query entry.
                         Default: vi. May contain arguments, e.g.
                         EDITOR="code --wait".
  MINDEX_QUERY           If set (even to a multi-line value), used directly
                         as the query and the editor step is skipped
                         entirely. Useful for cron jobs / CI / piping from
                         another program.

Examples:
  # Interactive, minimal:
  MINDEX_PROJECT=\$(uuidgen | tr -d - | tr A-Z a-z) $prog

  # Non-interactive, scripted:
  MINDEX_PROJECT=abc123... MINDEX_QUERY="parse a config file" \\
      MINDEX_TOP_K=10 $prog

  # Forward an extra flag mindex-search supports but this wrapper doesn't
  # have a dedicated environment variable for:
  MINDEX_PROJECT=abc123... $prog -- --no-verify
EOF
}

case "${1:-}" in
    -h | --help)
        show_help
        exit 0
        ;;
esac

# ─── Required tools ─────────────────────────────────────────────────────────

require_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        die "required tool not found on \$PATH: $1"
    fi
}

require_tool mktemp
require_tool grep
require_tool tr
require_tool dirname
require_tool basename

# ─── Resolve the mindex-search binary ──────────────────────────────────────

bin=${MINDEX_SEARCH_BIN:-}
if [ -z "$bin" ]; then
    script_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
    if [ -x "$script_dir/mindex-search" ]; then
        bin="$script_dir/mindex-search"
    elif command -v mindex-search >/dev/null 2>&1; then
        bin=mindex-search
    else
        die "mindex-search binary not found next to this script ($script_dir) or on \$PATH; set \$MINDEX_SEARCH_BIN to its path"
    fi
else
    if [ ! -x "$bin" ] && ! command -v "$bin" >/dev/null 2>&1; then
        die "\$MINDEX_SEARCH_BIN is set to '$bin' but it is not an executable file or a command on \$PATH"
    fi
fi

# ─── Validate required environment variables up front ──────────────────────
# Fail before opening the editor — don't make the user type a query only to
# discover a missing variable afterwards.

if [ -z "${MINDEX_PROJECT:-}" ]; then
    die "\$MINDEX_PROJECT is not set (required: 32-char hex project GUID without dashes). See --help."
fi

truthy() {
    val=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
    case "$val" in
        1 | true | yes | on) return 0 ;;
        *) return 1 ;;
    esac
}

# ─── Acquire the query ──────────────────────────────────────────────────────

tmpfile=$(mktemp "${TMPDIR:-/tmp}/mindex-search-query.XXXXXX") || die "mktemp failed to create a temp file"
trap 'rm -f "$tmpfile"' 0 1 2 3 15

if [ -n "${MINDEX_QUERY:-}" ]; then
    printf '%s\n' "$MINDEX_QUERY" >"$tmpfile"
else
    editor=${EDITOR:-vi}

    if [ -t 0 ] && [ -t 1 ]; then
        : # interactive terminal; the editor will take over the screen as expected
    else
        warn "stdin/stdout is not a terminal; \$EDITOR may not behave interactively. Consider setting \$MINDEX_QUERY instead."
    fi

    editor_status=0
    # Intentionally unquoted: $EDITOR conventionally may carry arguments,
    # e.g. EDITOR="code --wait".
    $editor "$tmpfile" || editor_status=$?
    if [ "$editor_status" -ne 0 ]; then
        die "editor exited with status $editor_status (\$EDITOR was: $editor); aborting"
    fi
fi

if ! grep -q '[^[:space:]]' "$tmpfile" 2>/dev/null; then
    die "query is empty (nothing but whitespace was entered); aborting"
fi

# ─── Translate MINDEX_* environment variables into mindex-search flags ─────
# Each step prepends to "$@", so env-derived flags always precede whatever
# the caller passed on this script's own command line — and since
# mindex-search applies flags in order with last-one-wins semantics for
# scalar options, CLI args given to this wrapper override the environment.

if [ -n "${MINDEX_SERVER:-}" ]; then
    set -- --server "$MINDEX_SERVER" "$@"
fi

set -- --project "$MINDEX_PROJECT" "$@"

if [ -n "${MINDEX_PROTOCOL:-}" ]; then
    set -- --protocol "$MINDEX_PROTOCOL" "$@"
fi

if [ -n "${MINDEX_NO_VERIFY:-}" ] && truthy "$MINDEX_NO_VERIFY"; then
    set -- --no-verify "$@"
fi

if [ -n "${MINDEX_TOP_K:-}" ]; then
    set -- --top-k "$MINDEX_TOP_K" "$@"
fi

if [ -n "${MINDEX_INCLUDE_LANG:-}" ]; then
    for lang in $MINDEX_INCLUDE_LANG; do
        set -- --include-lang "$lang" "$@"
    done
fi

if [ -n "${MINDEX_INCLUDE_PATH:-}" ]; then
    for glob in $MINDEX_INCLUDE_PATH; do
        set -- --include-path "$glob" "$@"
    done
fi

if [ -n "${MINDEX_EXCLUDE_LANG:-}" ]; then
    for lang in $MINDEX_EXCLUDE_LANG; do
        set -- --exclude-lang "$lang" "$@"
    done
fi

if [ -n "${MINDEX_EXCLUDE_PATH:-}" ]; then
    for glob in $MINDEX_EXCLUDE_PATH; do
        set -- --exclude-path "$glob" "$@"
    done
fi

if [ -n "${MINDEX_THEME:-}" ]; then
    set -- --theme "$MINDEX_THEME" "$@"
fi

if [ -n "${MINDEX_COLOR:-}" ]; then
    set -- --color "$MINDEX_COLOR" "$@"
fi

if [ -n "${MINDEX_VERBOSE:-}" ] && truthy "$MINDEX_VERBOSE"; then
    set -- --verbose "$@"
fi

# ─── Run it ──────────────────────────────────────────────────────────────────

status=0
"$bin" "$@" <"$tmpfile" || status=$?
exit "$status"
