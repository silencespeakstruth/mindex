# High-concurrency — demonstrates the request-parallelism axis. A large SQLite pool
# so many /index requests run at once, overlapping mindex's slicing + Qdrant upserts
# with the embedder's GPU work (which it serializes on one worker thread). This is the
# lever that recovers GPU idle time once each request is already a full forward pass.
# Keep MINDEX_DB_POOL_SIZE >= your client concurrency or requests get 500 (PoolEmpty);
# leave a little headroom for the GC/retry workers. Quieter logging under high RPS.
MINDEX_EMBED_BATCH=2048
MINDEX_DB_POOL_SIZE=64
MINDEX_MAX_BODY_MIB=512
MINDEX_STUCK_GRACE_MINS=30
MINDEX_MODEL_SERVER=http://host.docker.internal:11211
MINDEX_RUST_LOG=warn
