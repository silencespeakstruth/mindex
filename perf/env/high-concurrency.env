# Phase 3: push request-level parallelism. Keep DB pool >= the k6 concurrency you
# test so requests don't hit 500 (PoolEmpty).
MINDEX_EMBED_BATCH=2048
MINDEX_DB_POOL_SIZE=64
MINDEX_MAX_BODY_MB=512
MINDEX_STUCK_GRACE_MINS=30
MINDEX_MODEL_SERVER=http://host.docker.internal:11211
MINDEX_RUST_LOG=info
