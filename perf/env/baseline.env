# Baseline — stock defaults, the reference every other profile is compared against.
# Small embed-batch and pool: a single client, conservative memory. Pair with the
# host embedder at its default --batch. Start here, then compare big-batch /
# high-concurrency against it on YOUR hardware (the best config is machine-specific).
MINDEX_EMBED_BATCH=256
MINDEX_DB_POOL_SIZE=8
MINDEX_MAX_BODY_MIB=256
MINDEX_STUCK_GRACE_MINS=30
MINDEX_MODEL_SERVER=http://host.docker.internal:11211
MINDEX_RUST_LOG=info
