# Phase 2: large embed-batch so the embedder always has enough to fill a big --batch.
# Pair with a large host embedder --batch (e.g. 64/96/128).
MINDEX_EMBED_BATCH=2048
MINDEX_DB_POOL_SIZE=32
MINDEX_MAX_BODY_MB=512
MINDEX_STUCK_GRACE_MINS=30
MINDEX_MODEL_SERVER=http://host.docker.internal:11211
MINDEX_RUST_LOG=info
