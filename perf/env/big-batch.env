# Big-batch — demonstrates the GPU-batch axis. A large embed-batch + body limit so a
# single /index can carry many chunks into one big GPU forward pass. Pair with a large
# host embedder --batch and fat corpus shards (corpus/fetch.sh --shard-files N) — the
# forward batch is capped by chunks-per-request, not by this value. Raises GPU
# efficiency until the GPU saturates (often around batch ~64-128 — measure yours).
MINDEX_EMBED_BATCH=2048
MINDEX_DB_POOL_SIZE=16
MINDEX_MAX_BODY_MIB=512
MINDEX_STUCK_GRACE_MINS=30
MINDEX_MODEL_SERVER=http://host.docker.internal:11211
MINDEX_RUST_LOG=info
